   "id": "7f226141",
   "metadata": {},
   "outputs": [],
   "source": [
    "def rmsnorm(x, weight, eps=1e-6):\n",
    "    var = jnp.mean(jnp.square(x), axis=-1, keepdims = True)\n",
    "    return x*weight*jnp.reciprocal(jnp.sqrt(var+eps))"
   ]
